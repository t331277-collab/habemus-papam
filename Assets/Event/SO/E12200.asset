  eventID: E12200
  eventName: "\uD0DC\uC591\uC758 \uBC1C"
  eventDescription: "\"(\uB79C\uB364) \uD6C4\uBCF4\uAC00 \uB2F9\uC2E0\uC758 \uBC1C\uC5D0
    \uAE43\uB4E0 \uD0DC\uC591\uC758 \uBD88\uC744 \uC2DC\uD5D8\uD569\uB2C8\uB2E4.\n\n\uD0DC\uC591\uC758
    \uBC1C\uC744 \uC9C0\uB2CC \uC790\uC5EC, \uACE0\uACB0\uD568\uC744 \uC0C8\uACA8\uB77C.\""
  itemImage: {fileID: 0}
  maxAppear: 2
  eventWeightBase: 30
  eventWeightMultiplier: 0
  preEvents: []
  conflictEvents: []
  option1: "\uD0DC\uC591\uC758 \uD638\uD761\uC73C\uB85C \uBC1C\uC744 \uAD6C\uB978\uB2E4."
  option1Chance: 1
  option1SuccessDescription: "\"\uB2F9\uC2E0\uC740 \uC228\uC744 \uD06C\uAC8C \uB4E4\uC774\uC26C\uACE0,
    \uD0DC\uC591\uC758 \uAE30\uC6B4\uC744 \uB2F4\uC544 \uB0B4\uC270\uB2E4.\n\uADF8\uB9AC\uACE0\uB294
    \uC67C\uBC1C\uC744 \uB4E4\uC5B4\uC62C\uB9B0\uB2E4. \uC67C\uBC1C\uC774 \uB545\uC5D0
    \uB2FF\uAE30 \uC804\uC5D0 \uC624\uB978\uBC1C\uC744 \uB4E4\uC5B4\uC62C\uB9B0\uB2E4.\n\uB2F9\uC2E0\uC758
    \uB2E4\uB9AC\uB294 \uC2E0\uC131\uD55C \uBE5B\uC744 \uBC1B\uC544 \uB5A0\uC624\uB978\uB2E4.\n\uC5F0\uD68C\uC7A5\uC758
    \uBAA8\uB4E0 \uC0AC\uB78C\uB4E4\uC774 \uADF8 \uBAA8\uC2B5\uC5D0 \uB10B\uC744
    \uC783\uACE0 \uBC14\uB77C\uBCF8\uB2E4.\n\n\uACBD\uAC74\uD568 10 \uC99D\uAC00!\""
  option1FailDescription: 
  option2: "\uBC1C\uC5D0 \uBD88\uC774 \uBD99\uC744 \uB54C\uAE4C\uC9C0 \uBC1C\uBC14\uB2E5\uC744
    \uBE44\uBCBC \uBCF8\uB2E4."
  option2Chance: 0.7
  option2SuccessDescription: "\"\uB2F9\uC2E0\uC740 \uC228\uC744 \uD06C\uAC8C \uB4E4\uC774\uC26C\uACE0,
    \n\uC77C\uB2E8 \uC8FD\uC5B4\uB77C\uACE0 \uBC1C\uBC14\uB2E5\uC744 \uBE44\uBCBC
    \uBCF8\uB2E4.\n...\uC9C4\uC9DC\uB85C \uBC1C\uBC14\uB2E5\uC5D0 \uBD88\uC774 \uBD99\uC5C8\uB2E4!\n\uC9C4\uC9DC
    \uB728\uAC81\uB2E4!\n\n\uCCB4\uB825 10 \uAC10\uC18C!\n\uC774\uBC88 \uC36C\u3161\uD074\uB77C\uBCA0
    \uB3D9\uC548 \uC774\uB3D9\uC18D\uB3C4 30% \uC99D\uAC00!\n\""
  option2FailDescription: "\"\uB2F9\uC2E0\uC740 \uC228\uC744 \uD06C\uAC8C \uB4E4\uC774\uC26C\uACE0,\n\uC77C\uB2E8
    \uC8FD\uC5B4\uB77C\uACE0 \uBC1C\uBC14\uB2E5\uC744 \uBE44\uBCBC \uBCF8\uB2E4.\n...\uADF8\uB9CC
    \uBC1C\uBAA9\uC744 \uC811\uC9C0\uB974\uACE0 \uB9D0\uC558\uB2E4!\n\uC9C4\uC9DC
    \uC544\uD504\uB2E4!\n\n\uCCB4\uB825 10 \uAC10\uC18C!\n\uC774\uBC88 \uC36C\u3161\uD074\uB77C\uBCA0
    \uB3D9\uC548 \uC774\uB3D9\uC18D\uB3C4 20% \uAC10\uC18C!\""
