  eventName: "\uCF5C\uBC84\uC2A4\uC758 \uC120\uC6D0"
  eventDescription: "\"\uB0A1\uC740 \uC120\uC6D0\uBCF5\uC744 \uC785\uC740 \uD55C
    \uC80A\uC740\uC774\uAC00 \uC5F0\uD68C\uC7A5 \uBB38\uC744 \uAC70\uC138\uAC8C \uB450\uB4DC\uB9AC\uACE0
    \uC788\uB2E4!\n\uC790\uC2E0\uC774 \uAD50\uB2E8 \uC218\uC11D \uD0D0\uD5D8\uAC00\uC778
    \uCF5C\uBC84\uC2A4\uAC00 \uC774\uB048 \uD0D0\uC0AC\uB300\uC758 \uB9C8\uC9C0\uB9C9
    \uC0DD\uC874\uC790\uB77C\uACE0 \uC8FC\uC7A5\uD558\uB294 \uADF8\uB294,\n\uAC11\uC790\uAE30
    \uBC14\uB2E4 \uD55C\uAC00\uC6B4\uB370\uC5D0 \uAC70\uB300\uD55C \uD3ED\uD3EC\uAC00
    \uB098\uD0C0\uB098 \uD0D0\uC0AC\uC120\uB4E4\uC774 \uBAA8\uB450 \uD729\uC4F8\uB824
    \uBC84\uB838\uB2E4\uACE0 \uB9D0\uD55C\uB2E4!\n\uADF8\uAC00 \uAC00\uC838\uC628
    \uAE30\uB85D\uC740 \uC9C4\uC9DC\uC784\uC5D0 \uD2C0\uB9BC\uC5C6\uC73C\uB098, \uB0B4\uC6A9\uC774
    \uB108\uBB34\uB098\uB3C4 \uD130\uBB34\uB2C8\uC5C6\uB2E4!\n\uC774 \uC0AC\uB78C\uC744
    \uBBFF\uACE0 \uC870\uC0AC\uB97C \uB9E1\uACA8\uBD10\uC57C \uD560\uAE4C?\""
