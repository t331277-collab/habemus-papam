  option2Chance: 0.5
  option2SuccessDescription: "\uD479 \uC7A4\uB354\uB2C8 \uCCB4\uB825\uC774 \uD68C\uBCF5\uB418\uC5C8\uB2E4!\n\uD0DC\uC591\uB9CC\uC138
