  eventName: "\uC0C8\uB85C\uC6B4 \uC804\uB840"
  eventDescription: "\uCF85!\n\uD68C\uB2F4\uC7A5\uC758 \uACE0\uC694\uD55C \uC815\uC801\uC744
    \uAE68\uACE0, \uB204\uAD70\uAC00 \uCC45\uC0C1\uC5D0 \uC544\uC8FC \uB450\uAEBC\uC6B4
    \uC11C\uB958 \uBB49\uCE58\uB97C \uC62C\uB824\uB193\uC558\uB2E4.\n\uAC1C\uD601\uC8FC\uC758\uC790\uC778
    (\uD6C4\uBCF4 2)\uC600\uB2E4.\n\uADF8\uB294 \uC804\uD1B5\uC801\uC778 \uAD50\uB9AC\uAC00
    \uC2DC\uB300\uC801 \uD604\uC2E4\uC5D0 \uB9DE\uC9C0 \uC54A\uB2E4\uBA74\uC11C,\n\uC790\uC2E0\uC774
    \uCC3D\uC548\uD55C '\uD0DC\uC591\uC758 \uC804\uB840'\uB97C \uC815\uC2DD \uBBF8\uC0AC
    \uC808\uCC28\uB85C \uC778\uC815\uD560 \uAC83\uC744 \uC694\uAD6C\uD558\uC600\uB2E4.\n\uC11C\uB958\uB97C
    \uC77D\uC5B4 \uBCFC\uAE4C?\""
  itemImage: {fileID: 0}
  maxAppear: 1
  eventWeightBase: 40
  eventWeightMultiplier: 0.1
  preEvents: []
  conflictEvents: []
  option1: "\uBC88\uAC70\uB86D\uB354\uB77C\uB3C4 \uC11C\uB958\uB97C \uC77D\uC5B4
    \uBCF8\uB2E4!"
  option1Chance: 1
  option1Requirement: 
  option1SuccessDescription: "\uC804\uD1B5\uC801\uC778 \uBBF8\uC0AC\uC5D0\uB294 \uB113\uC740
    \uC232\uC774 \uD544\uC694\uD574\uC11C,\n\uB3C4\uC2DC \uC9C0\uC5ED\uC758 \uC0AC\uB78C\uB4E4\uC774
    \uD560 \uC218 \uC5C6\uB2E4\uB294 \uB17C\uC9C0\uC600\uB2E4.\n(\uD6C4\uBCF4 2)\uC758
    \uC0AC\uB824 \uAE4A\uC740 \uC0DD\uAC01\uC774 \uB290\uAEF4\uC9C4\uB2E4\uB9CC,\n\uB0B4\uC6A9\uC774
    \uC9C0\uB098\uCE58\uAC8C \uAE09\uC9C4\uC801\uC774\uB77C \uD1B5\uACFC\uC5D0 \uC5B4\uB824\uC6C0\uC744
    \uACAA\uC744 \uAC83 \uAC19\uB2E4.\n\uBAA8\uB974\uACA0\uB2E4. \uB09C \uBB50\uAC00
    \uB410\uB4E0 \uC740\uD1F4\uD558\uBA74 \uADF8\uB9CC\uC774\uB2C8\uAE4C!"
  option1SuccessResult: 
  option1FailDescription: 
  option1FailResult: 
  option2: "\uC774\uB7F0 \uC88B\uC740 \uBCA0\uAC1C\uAC00? \uC11C\uB958 \uB354\uBBF8\uB97C
