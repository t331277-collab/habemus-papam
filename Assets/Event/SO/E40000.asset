  eventName: "\uC0B0\uCC45"
  eventDescription: "\uC0C8\uB4E4\uC740 \uC9C0\uC800\uADC0\uACE0, \uAF43\uB4E4\uC740
    \uD53C\uC5B4\uB098\uACE0... \uC0B0\uCC45 \uB098\uAC00\uAE30 \uB531 \uC88B\uC740
