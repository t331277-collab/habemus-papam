  maxAppear: 1
  eventWeightBase: 20
  eventWeightMultiplier: 0
  preEvents: []
  conflictEvents: []
  option1: "\uD760... \uC544\uBB34\uB9AC \uBD10\uB3C4 \uC218\uC0C1\uD558\uB2E4.\n\uC8FC\uC704\uB97C 
