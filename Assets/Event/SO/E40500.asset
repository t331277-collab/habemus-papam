  option1: "\uC9D1\uC73C\uB85C \uC218\uD589\uC6D0\uC744 \uBCF4\uB0B8\uB2E4."
  option1Chance: 0.8
  option1Requirement: "\uC815\uCE58\uB825 40 \uC774\uC0C1"
  option1SuccessDescription: "\uC9C4\uC9DC \uBD88\uC774 \uCF1C\uC838 \uC788\uC5C8\uB2E4!\n\uD734,
