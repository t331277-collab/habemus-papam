  eventName: "\uC8FC\uD654\uC785\uB9C8"
  eventDescription: "\uC544\uCE68\uBD80\uD130 \uC5B4\uB5A4 \uC0DD\uAC01\uC774 \uB2F9\uC2E0\uC744
