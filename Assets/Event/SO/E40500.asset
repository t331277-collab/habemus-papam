  option1FailResult: '-'
  option2: "\uBB50 \uC190 \uC4F8 \uC218\uB2E8\uC774 \uC5C6\uB2E4.\n\uC774 \uC77C\uC744
    \uB9C8\uCE58\uACE0 \uBE68\uB9AC \uAC00\uBCF4\uB294 \uC218\uBC16\uC5D0."
  option2Chance: 0.8
  option2SuccessDescription: "\uC640\uC7A5\uCC3D!\n\uC9D1\uC911\uB825\uC774 \uD750\uD2B8\uB7EC\uC9C4
