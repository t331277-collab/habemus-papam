  eventName: "\uBC18\uB780\uBAA8\uC758"
  eventDescription: "\"\uC54C\uB798\uC2A4\uCE74\uB85C \uC7A0\uC801\uD55C (\uD6C4\uBCF4
    3)\uC774(\uAC00) \uBD81\uADF9\uACF0\uB4E4\uACFC \uD568\uAED8 \uBC18\uB780\uC744
    \uBAA8\uC758\uD558\uACE0 \uC788\uB2E4\uB294 \uCCA9\uBCF4\uAC00 \uB4E4\uC5B4\uC654\uB2E4.\n\uAD50\uB2E8
    \uB0B4 \uCD5C\uACE0 \uAC15\uACBD\uD30C\uC778 (\uD6C4\uBCF4 1)\uC640(\uACFC) (\uD6C4\uBCF4
    2)\uC774(\uAC00) \uD798\uC744 \uBAA8\uC544 \uC131\uC804\uC744 \uC8FC\uC7A5\uD558\uB294
    \uAC00\uC6B4\uB370,\n\uB9CE\uC740 \uCD94\uAE30\uACBD\uB4E4\uC774 \uB2F9\uC2E0\uC774
    \uC55E\uC7A5\uC11C \uBD84\uC704\uAE30 \uACFC\uC5F4\uC744 \uB9C9\uAE30\uB97C \uC6D0\uD558\uACE0
    \uC788\uB2E4!\n\uAD50\uB2E8\uC758 \uC6B4\uBA85\uC774 \uB2F9\uC2E0\uC758 \uC190\uC5D0
    \uB2EC\uB838\uB2E4! \uB2F9\uC2E0\uC774 \uC6D0\uD558\uB294 \uAC83\uC740 \uBB34\uC5C7\uC77C\uAE4C?\""
  itemImage: {fileID: 0}
  maxAppear: 1
  eventWeightBase: 20
  eventWeightMultiplier: 0
  preEvents: []
  conflictEvents: []
  option1: "\uD3C9\uD654\uB2E4!"
  option1Chance: 1
  option1SuccessDescription: "\"\uD53C \uB9D0\uB9AC\uB294 \uD68C\uC758 \uB05D\uC5D0,
    \uC6D0\uB300\uD55C \uAD70\uC0AC \uC791\uC804\uC740 \uC740\uBC00\uD55C \uCCA9\uBCF4
    \uC791\uC804\uC73C\uB85C \uCD95\uC18C\uB418\uC5C8\uB2E4!\n\uAD50\uB2E8 \uD2B9\uC0AC\uB97C
    \uBCF4\uB0B4 \uBC18\uB780\uAD70\uACFC \uD611\uC0C1\uC744 \uD558\uB294 \uCC99\uD558\uBA74\uC11C,
    \uCCA9\uBCF4\uC6D0\uC744 \uBCF4\uB0B4\uC11C \uB0B4\uBD80\uC758 \uC0AC\uAE30\uB97C
    \uAEBE\uB294\uB2E4.\n\uC774\uD6C4 300\uBA85 \uC815\uB3C4\uC758 \uD2B9\uC218\uBD80\uB300\uB9CC
    \uBCF4\uB0B4\uBA74 \uC544\uBB34\uB9AC \uB9CE\uC740 \uBD81\uADF9\uACF0\uC774\uB77C\uB3C4
    \uD3EC\uC704\uC12C\uBA78\uD560 \uC218 \uC788\uC744 \uAC83\uC774\uB2E4!\n\uAD50\uB2E8\uC774
    \uD3C9\uD654\uB97C \uB418\uCC3E\uC558\uB2E4! \uB2F9\uC2E0\uC740 \uD3C9\uD654\uC758
    \uC0AC\uB3C4\uB85C\uC11C \uD070 \uC874\uACBD\uC744 \uBC1B\uAC8C \uB418\uC5C8\uB2E4!
    \uC88B\uC740 \uAC74\uAC00?\n\n\uACBD\uAC74\uD568 40 \uC99D\uAC00!\n\uC815\uCE58\uB825
    15 \uC99D\uAC00!\""
  option1FailDescription: 
  option2: "\uC131\uC804\uC740 \uB0B4 \uC54C \uBC14 \uC544\uB2C8\uACE0, \uC548\uB77D\uD55C
    \uB178\uD6C4\uB2E4!"
  option2Chance: 1
  option2SuccessDescription: "\"\uB2F9\uC2E0\uC740 \uC790\uC2E0\uC758 \uC548\uC704
    \uC55E\uC5D0 \uB208\uC744 \uAC10\uACE0\uC57C \uB9D0\uC558\uB2E4.\n\uC815\uC801\uC774\uC600\uB358
    (\uD6C4\uBCF4 1)\uC640(\uACFC) (\uD6C4\uBCF4 2)\uC758 \uD569\uB3D9 \uACF5\uC791\uC744
    \uB9C9\uC544\uC124 \uCD94\uAE30\uACBD\uC740 \uC544\uBB34\uB3C4 \uC5C6\uC5C8\uB2E4.\n\uCE58\uC5F4\uD55C
    \uC815\uCE58 \uC554\uD22C\uADF9 \uB05D\uC5D0, (\uD6C4\uBCF4 1)\uC740(\uB294)
    \uACB0\uAD6D (\uD6C4\uBCF4 2)\uC744(\uB97C) \uC554\uC0B4\uD558\uACE0 \uAD50\uC8FC
    \uC790\uB9AC\uC5D0 \uC62C\uB790\uB2E4.\n\uC131\uC804\uC774 \uC120\uD3EC\uB418\uC5C8\uB2E4.
    \uC8FC\uC0AC\uC704\uB294 \uB358\uC838\uC84C\uB2E4. \uCD9C\uBCD1\uC2DD\uC744 \uC55E\uB454
    (\uD6C4\uBCF4 1)\uC758 \uB208\uAE38\uC5D0\uB294 \uD55C \uCE58\uC758 \uB9DD\uC124\uC784\uB3C4
    \uC5C6\uC5C8\uB2E4!\n\n\uB0A8\uC740 \uD6C4\uBCF4 \uC989\uC2DC \uD0C8\uB77D!\n\uC36C\u3161\uD074\uB77C\uBCA0
    \uC885\uACB0!\""
