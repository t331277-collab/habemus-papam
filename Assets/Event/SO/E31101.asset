  eventID: E31101
  eventName: "\uBD81\uAE08\uACF0\uC758 \uBC18\uB780"
  eventDescription: "\"\uBD81\uADF9\uACF0\uB4E4\uC774 \uCCD0\uB4E4\uC5B4\uC628\uB2E4!\n\uC54C\uB798\uC2A4\uCE74\uB85C
    \uC7A0\uC801\uD588\uB358 (\uD6C4\uBCF4 3)\uC774 \uBE44\uBC00\uB9AC\uC5D0 \uC721\uC131\uD588\uB358
    \uBD81\uADF9\uACF0\uB4E4\uC774 \uC55E\uBC1C\uC5D0 \uCF5C\uB77C\uB97C \uB4E4\uACE0
    \uB300\uC2E0\uC804 \uC55E\uAE4C\uC9C0 \uBC00\uB824\uB4E4\uC5B4\uC654\uB2E4!\n\uAD50\uB2E8\uC758
    \uD2B9\uC218\uBD80\uB300\uAC00 \uC804\uBA78\uD55C \uC0C1\uD669, \uC774\uC81C
    \uBD81\uADF9\uACF0 \uAD70\uB2E8\uC744 \uB9C9\uC744 \uC218 \uC788\uB294 \uAC74
    \uC2E0\uC131\uD55C \uD0DC\uC591\uC758 \uD798\uBC16\uC5D0 \uC5C6\uB2E4!\n\uC9C0\uAE08
    \uB0B4\uAC00 \uB098\uC11C \uD574\uACB0\uD558\uC9C0 \uC54A\uC73C\uBA74 \uB178\uD6C4\uB294
    \uBB34\uC2A8, \uC9C0\uD558\uAC10\uC625\uC5D0\uC11C \uD3C9\uC0DD\uC744 \uC369\uC5B4\uC57C
    \uD560 \uC218\uB3C4 \uC788\uB2E4!\""
  itemImage: {fileID: 0}
