  option1: "\uD0DC\uC591\uC758 \uD798\uC744 \uBCF4\uC5EC \uC900\uB2E4!"
  option1Chance: 1
  option1SuccessDescription: "\"\uB2F9\uC2E0\uC740 \uC228\uC744 \uD06C\uAC8C \uB4E4\uC774\uC26C\uACE0,
    \uD0DC\uC591\uC758 \uAE30\uC6B4\uC744 \uB2F4\uC544 \uB0B4\uC270\uB2E4.\n\uB2F9\uC2E0\uC758
    \uB208\uC740 \uD0DC\uC591\uCC98\uB7FC \uBE5B\uB09C\uB2E4. \uB2F9\uC2E0\uC758
    \uB2E4\uB9AC\uB294 \uBD88\uCC98\uB7FC \uAC15\uC778\uD558\uB2E4.\n\uC785\uAE40\uC774
    \uB2FF\uB294 \uACF3\uB9C8\uB2E4 \uD0DC\uC591\uC758 \uAE30\uC6B4\uC73C\uB85C \uCDA9\uB9CC\uD558\uB2E4.\n\uBD81\uADF9\uACF0\uB4E4\uC740
    \uD0DC\uC591\uC758 \uAE30\uC6B4\uC5D0 \uAC10\uD654\uB418\uC5B4 \uB2F9\uC2E0\uC5D0\uAC8C
    \uAE68\uB2EC\uC74C\uC744 \uAC08\uAD6C\uD55C\uB2E4.\n\uD0DC\uC591\uC758 \uCD95\uBCF5
    \uBC1B\uC740 \uC790\uC5EC, \uAE30\uBED0\uD558\uB77C.\n\n\uC2B9\uB9AC!\""
  option1FailDescription: 
  option2: "\uB3C4\uB9DD\uAC04\uB2E4. \uACF0\uC740 \uC0AC\uB78C\uC744 \uCC22\uC5B4."
  option2Chance: 1
  option2SuccessDescription: "\"\uB2F9\uC2E0\uC740 \uC228\uC744 \uD06C\uAC8C \uB4E4\uC774\uC26C\uACE0,
    \uBC1C\uC5D0 \uBD88\uC774 \uB098\uB3C4\uB85D \uAD74\uB7EC \uB3C4\uB9DD\uAC04\uB2E4.\n\uAD50\uB2E8\uC740
    (\uD6C4\uBCF4 3)\uC640(\uACFC) \uBD81\uADF9\uACF0\uB4E4\uC774 \uC138\uC6B4, \uC54C\uB798\uC2A4\uCE74
    \uD2B8\uB85C\uCE20\uD0A4\uC8FC\uC758 \uC0AC\uD68C\uC778\uBBFC\uACF5\uD654\uAD6D\uC774
    \uC811\uC218\uD55C\uB2E4.\n\uB9CC\uAD6D\uC758 \uC778\uBBFC\uC774\uC5EC, \uB2E8\uACB0\uD558\uB77C.
    \uBD81\uADF9\uACF0 \uB9CC\uC138, \uC0AC\uD68C\uC8FC\uC758 \uB9CC\uC138, (\uD6C4\uBCF4
    3) \uB9CC\uC138.\""
