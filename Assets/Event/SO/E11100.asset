  option2Chance: 1
  option2SuccessDescription: "\uC81C\uD55C\uC2DC\uAC04\uC774 \uB05D\uB098\uBA74 \uD22C\uD45C\uB97C
    \uC9C4\uD589\uD569\uB2C8\uB2E4.\n\uB2A5\uB825\uCE58\uAC00 \uAC00\uC7A5 \uB192\uC740
