  eventID: E12100
  eventName: "\uD0DC\uC591\uC758 \uB208"
  eventDescription: "\"(\uB79C\uB364) \uD6C4\uBCF4\uAC00 \uB2F9\uC2E0\uC758 \uB208\uC5D0
    \uAE43\uB4E0 \uD0DC\uC591\uC758 \uBE5B\uC744 \uC2DC\uD5D8\uD569\uB2C8\uB2E4.\n\n\uD0DC\uC591\uC758
    \uB208\uC744 \uC9C0\uB2CC \uC790\uC5EC, \uC2E0\uC2E4\uD568\uC744 \uBCF4\uC5EC\uB77C.\""
  itemImage: {fileID: 0}
  maxAppear: 2
  eventWeightBase: 30
  eventWeightMultiplier: 0
  preEvents: []
  conflictEvents: []
  option1: "\uB0B4 \uC548\uC5D0 \uC228\uACA8\uC9C4 \uC2E0\uC131\uD55C \uD0DC\uC591
    \uC5D0\uB108\uC9C0\uB97C \uBCF4\uC5EC \uC900\uB2E4."
  option1Chance: 1
  option1Requirement: 
  option1SuccessDescription: "\uB2F9\uC2E0\uC740 \uD6C4\uB4DC\uB97C \uBC97\uACE0,
    \uADF8 \uC18D\uC5D0 \uC228\uACA8\uC9C4 \uC2E0\uC131\uD55C \uD0DC\uC591 \uC5D0\uB108\uC9C0\uB97C
    \uBCF4\uC5EC\uC90D\uB2C8\uB2E4. \uCC2C\uB780\uD55C \uD0DC\uC591\uC758 \uBE5B\uC744
    \uBC18\uC0AC\uD55C \uB9E4\uB048\uB9E4\uB048\uD55C \uB2F9\uC2E0\uC758 \uC774\uB9C8\uB97C
    \uBCF4\uACE0, \uC8FC\uBCC0 \uC88C\uC911\uC774 \uBAA8\uB450 \uAC10\uD0C4\uC744
    \uAE08\uCE58 \uBABB\uD569\uB2C8\uB2E4."
  option1SuccessResult: 
  option1FailDescription: 
  option1FailResult: 
  option2: "\uC2E0\uC559\uC744 \uAC80\uC99D\uD558\uAE30 \uC704\uD574 \uD0DC\uC591\uC744
    \uB6AB\uC5B4\uC838\uB77C \uCCD0\uB2E4\uBCF8\uB2E4."
  option2Chance: 0.5
  option2SuccessDescription: "\uD0DC\uC591\uC758 \uCC2C\uB780\uD55C \uC5D0\uB108\uC9C0\uAC00
    \uB300\uB1CC\uC758 \uC804\uB450\uC5FD\uC744 \uAFF0\uB6AB\uB294\uB2E4. \uB2F9\uC2E0\uC758
    \uACBD\uAC74\uD55C \uBAA8\uC2B5\uC744 \uBC14\uB77C\uBCF8 \uB2E4\uB978 \uCD94\uAE30\uACBD\uB4E4\uC740
    \uAC10\uD0C4\uD55C\uB2E4.\n\uB208\uC740 \uC544\uD504\uC9C0\uB9CC \uBAB8\uC774
    \uAC74\uAC15\uD574\uC9C0\uB294 \uB290\uB08C\uC774\uB2E4.\n\uAE30\uBD84 \uD0D3\uC77C\uAE4C?"
  option2SuccessResult: "\uAE30\uBD84 \uD0D3\uC774 \uB9DE\uB2E4. \uCCB4\uB825 10
    \uAC10\uC18C!"
  option2FailDescription: "\uD0DC\uC591\uC758 \uCC2C\uB780\uD55C \uC5D0\uB108\uC9C0\uB97C
    \uBC1B\uC544\uB4E4\uC774\uB2E4 \uBABB\uD574 \uADF8\uB9CC \uB208\uC744 \uAC10\uACE0
    \uB9D0\uC558\uB2E4.\n\uB208\uBB3C\uC774 \uB09C\uB2E4.\n\uD0DC\uC591 \uC55E\uC5D0\uC11C
    \uB208\uBB3C\uC744 \uD758\uB9AC\uB294 \uB2F9\uC2E0\uC758 \uBAA8\uC2B5\uC744 \uBCF8
    \uB2E4\uB978 \uD6C4\uBCF4\uB4E4\uC740 \uAC10\uB3D9\uC744 \uAE08\uCE58 \uBABB\uD55C\uB2E4."
  option2FailResult: "\uCCB4\uB825 20 \uAC10\uC18C!"
