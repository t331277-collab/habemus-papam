    \uC790\uB4E4\uC740 \uBAA8\uB450 \uD0DC\uC591\uC5D0 \uC758\uD574 \uBD88\uC0B4\uB77C\uC9C8
    \uAC83\uC774\uB2E4!\n\n\uACBD\uAC74\uD568 10 \uAC10\uC18C!\n\uC5F0\uC124 \uC2DC\uB9C8\uB2E4
