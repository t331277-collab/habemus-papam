  eventID: E32000
  eventName: "\uD3ED\uD0C4 \uD14C\uB7EC!"
  eventDescription: "\uB300\uC2E0\uC804 \uC55E \uAD11\uC7A5\uC5D0\uC11C \uC774\uAD50\uB3C4\uC758
    \uBAA8\uC790\uB97C \uC4F4 \uD55C \uC80A\uC740\uC774\uAC00 \uACE0\uD568\uC744
    \uC9C0\uB974\uACE0 \uC788\uB2E4.\n'\uC0C8\uB85C\uC6B4 \uACBD\uC804\uC5D0 \uB530\uB77C
    \uD0DC\uC591\uC740 \uB2EC\uC758 \uD558\uC218\uC778\uC784\uC744 \uC778\uC815\uD558\uB77C!'\n\uADF8\uC758
    \uC870\uB07C\uC5D0\uB294... \uD3ED\uD0C4\uC774 \uB458\uB7EC\uC838 \uC788\uB2E4!"
  itemImage: {fileID: 0}
  maxAppear: 1
  eventWeightBase: 40
  eventWeightMultiplier: 0
  preEvents: []
  conflictEvents: []
  option1: "\uC774\uAD50\uB3C4\uC640\uC758 \uB300\uD654\uB97C \uC2DC\uB3C4\uD55C\uB2E4!"
  option1Chance: 0.9
  option1Requirement: 
  option1SuccessDescription: "\uB2F9\uC2E0\uC740 \uBE60\uB974\uAC8C \uD68C\uC758\uC7A5\uC758
    \uBD84\uC704\uAE30\uB97C \uC9C4\uC815\uC2DC\uD0A4\uACE0, \uC774\uAD50\uB3C4\uB97C
    \uC124\uB4DD\uD574 \uB3CC\uB824\uBCF4\uB0BC \uBC29\uBC95\uC744 \uBB3C\uC0C9\uD55C\uB2E4.\n\uD3C9\uD654\uC8FC\uC758\uC790\uC778
    (\uD6C4\uBCF4 2)\uC774(\uAC00) \uB098\uC640\uC11C, \uD3C9\uD654\uB97C \uC124\uD30C\uD558\uBA70
    \uC774\uAD50\uB3C4\uB97C \uCD95\uBCF5\uD558\uACE0 \uD3EC\uC639\uD558\uB294\uB370...\n\uD479,
    \uD558\uB294 \uC18C\uB9AC\uC640 \uD568\uAED8 (\uD6C4\uBCF4 2)\uC758 \uB85C\uBE0C\uC5D0
    \uD53C\uAC00 \uD765\uAC74\uD574\uC9C4\uB2E4.\n\uADF8\uB7EC\uB098 \uADF8\uB294
    \uC77C\uB9D0\uC758 \uC99D\uC624\uB3C4 \uB4DC\uB7EC\uB0B4\uC9C0 \uC54A\uACE0,
    \uC778\uC790\uD55C \uC6C3\uC74C\uC73C\uB85C \uC6A9\uC11C\uC640 \uD3C9\uD654\uC758
    \uBA54\uC138\uC9C0\uB97C \uC804\uD588\uB2E4!\n\uACB0\uAD6D \uC774\uAD50\uB3C4\uB294
    \uB208\uBB3C\uC744 \uD758\uB9AC\uBA70 \uC870\uB07C\uB97C \uBC97\uB294\uB2E4.\n\n\uC36C\u3161\uD074\uB77C\uBCA0
    \uC911\uB2E8!\n(\uD6C4\uBCF4 2)\uC758 \uACBD\uAC74\uD568 80 \uC99D\uAC00!\n(\uD6C4\uBCF4
    2) \uC4F0\uB7EC\uC9D0!"
  option1SuccessResult: "\uD574\uB2F9 \uCF58\uD074\uB77C\uBCA0 \uC989\uC2DC \uC885\uB8CC\n\uD6C4\uBCF4
    2 \uACBD\uAC74\uD568 +80\n\uD6C4\uBCF4 2 \uCCB4\uB825 -100"
  option1FailDescription: "\uB2F9\uC2E0\uC740 \uBE60\uB974\uAC8C \uD68C\uC758\uC7A5\uC758
    \uBD84\uC704\uAE30\uB97C \uC9C4\uC815\uC2DC\uD0A4\uACE0, \uC774\uAD50\uB3C4\uB97C
    \uC124\uB4DD\uD574 \uB3CC\uB824\uBCF4\uB0BC \uBC29\uBC95\uC744 \uBB3C\uC0C9\uD55C\uB2E4.\n\uD3C9\uD654\uC8FC\uC758\uC790\uC778
    (\uD6C4\uBCF4 2)\uC774(\uAC00) \uB098\uC640\uC11C, \uD3C9\uD654\uB97C \uC124\uD30C\uD558\uBA70
    \uC774\uAD50\uB3C4\uC640 \uC545\uC218\uB97C \uD558\uB824\uACE0 \uD558\uC790...\n\uD391!
    \uADC0\uCCAD\uC774 \uB5A8\uC5B4\uC838 \uB098\uAC08 \uAC83 \uAC19\uC740 \uBB34\uC2DC\uBB34\uC2DC\uD55C
    \uD3ED\uC74C\uACFC \uD568\uAED8 \uD3ED\uD0C4 \uC870\uB07C\uAC00 \uD130\uC9C0\uACE0
    \uB9D0\uC558\uB2E4.\n\uD68C\uC758\uC7A5\uC774 \uD63C\uBE44\uBC31\uC0B0\uC5D0
    \uBE60\uC9C4\uB2E4.\n\n\uC36C\u3161\uD074\uB77C\uBCA0 \uC911\uB2E8!\n(\uD6C4\uBCF4
    2) \uC0AC\uB9DD!\n\uBAA8\uB4E0 \uD6C4\uBCF4\uC758 \uCCB4\uB825 20 \uAC10\uC18C!\n\uBAA8\uB4E0
    \uD6C4\uBCF4\uC758 \uC815\uCE58\uB825 30 \uAC10\uC18C!"
  option1FailResult: "\uD574\uB2F9 \uCF58\uD074\uB77C\uBCA0 \uC989\uC2DC \uC885\uB8CC\n\uD6C4\uBCF4
    2 \uD0C8\uB77D \uCC98\uB9AC\n\uD50C\uB808\uC774\uC5B4\uC640 \uD6C4\uBCF4 1, 2,
    3 \uCCB4\uB825 -20\n\uD50C\uB808\uC774\uC5B4\uC640 \uD6C4\uBCF4 1, 2, 3 \uC815\uCE58\uB825
    -30"
  option2: "\uC800\uACA9\uC218\uB97C \uBC30\uCE58\uD574 \uC774\uAD50\uB3C4\uB97C
    \uC0AC\uC0B4\uD55C\uB2E4!"
  option2Chance: 1
  option2SuccessDescription: "\uAD50\uB2E8 \uADFC\uC704\uB300\uC5D0 \uC5F0\uB77D\uD558\uC5EC
    \uC740\uBC00\uD788 \uC800\uACA9\uC218\uB97C \uBC30\uCE58\uD558\uC600\uB2E4.\n\uADFC\uC704\uB300\uC640\uC758
    \uAE34 \uB300\uCE58 \uB05D\uC5D0 \uC774\uAD50\uB3C4\uAC00 \uD3ED\uD0C4 \uC870\uB07C\uB97C
    \uB9CC\uC9C0\uB824 \uD558\uC790,\n\uBC84\uD2BC\uC744 \uB204\uB974\uAE30\uB3C4
    \uC804\uC5D0 \uCD1D\uC54C\uC774 \uADF8\uC758 \uBA38\uB9AC\uB97C \uAFF0\uB6AB\uC5C8\uB2E4.\n\uD63C\uB780\uC5D0
    \uBE60\uC9C4 \uAD70\uC911\uC744 \uADFC\uC704\uB300\uAC00 \uBE60\uB974\uAC8C \uD574\uC0B0\uC2DC\uCF30\uB2E4.\n\n\uC36C\u3161\uD074\uB77C\uBCA0
    \uC911\uB2E8!\n\uBAA8\uB4E0 \uD6C4\uBCF4 \uACBD\uAC74\uD568 40 \uAC10\uC18C!"
  option2SuccessResult: "\uD50C\uB808\uC774\uC5B4\uC640 \uD6C4\uBCF4 1, 2, 3 \uACBD\uAC74\uD568
    -40"
