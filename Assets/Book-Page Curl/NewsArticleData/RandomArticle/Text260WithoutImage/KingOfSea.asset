  m_Script: {fileID: 11500000, guid: 26a8f68cbc14db84b9de0657036a1003, type: 3}
  m_Name: KingOfSea
  m_EditorClassIdentifier: Assembly-CSharp::ArticleData
  title: "\uC5B4\uBD80, \uBC14\uB2E4\uC758 \uC655 \uC790\uCC98\uD558\uBA70 \uD1B5\uD589\uB8CC
    \uC694\uAD6C"
  image: {fileID: 0}
  body: "\uB0A8\uBD80 \uD56D\uAD6C\uC5D0\uC11C \uD55C \uC5B4\uBD80\uAC00 \uBC14\uB2E4\uC758
    \uC655\uC5D0\uAC8C \uC784\uBA85\uBC1B\uC558\uB2E4\uBA70 \uBAA8\uB4E0 \uC120\uBC15\uC5D0
    \u2018\uD30C\uB3C4 \uD1B5\uD589\uB8CC\u2019\uB97C \uC694\uAD6C\uD558\uAE30 \uC2DC\uC791\uD588\uB2E4.
    \uADF8\uB294 \uCEE4\uB2E4\uB780 \uBB38\uC5B4\uAC00 \uAFC8\uC5D0 \uB098\uD0C0\uB098
    \uC870\uAC1C\uAECD\uB370\uAE30 \uC655\uAD00\uC744 \uAC74\uB124\uC92C\uB2E4\uACE0
    \uC8FC\uC7A5\uD588\uB2E4. \uCC98\uC74C\uC5D0\uB294 \uBAA8\uB450\uAC00 \uBE44\uC6C3\uC5C8\uC9C0\uB9CC,
    \uD1B5\uD589\uB8CC\uB97C \uB0B4\uC9C0 \uC54A\uC740 \uBC30 \uC8FC\uBCC0\uC5D0\uC11C
    \uAC11\uC790\uAE30 \uD30C\uB3C4\uAC00 \uAC70\uC138\uC9C0\uBA74\uC11C \uC0C1\uC778\uB4E4\uC774
    \uB3C8\uC744 \uB0B4\uAE30 \uC2DC\uC791\uD588\uB2E4. \uC655\uC2E4 \uD574\uAD70\uC774
    \uCCB4\uD3EC\uC5D0 \uB098\uC11C\uC790 \uC5B4\uBD80\uB294 \uC790\uC2E0\uC5D0\uAC8C
    \uC721\uC9C0\uC758 \uBC95\uC774 \uC801\uC6A9\uB418\uC9C0 \uC54A\uB294\uB2E4\uBA70
    \uBC14\uB2E4\uB85C \uB6F0\uC5B4\uB4E4\uC5C8\uB2E4. \uD558\uC9C0\uB9CC \uBB3C\uC774
    \uD5C8\uB9AC\uAE4C\uC9C0\uBC16\uC5D0 \uC624\uC9C0 \uC54A\uC544 \uACE7\uBC14\uB85C
    \uBD99\uC7A1\uD614\uACE0, \uBB38\uC81C\uC758 \uD30C\uB3C4\uB294 \uADFC\uCC98
    \uACE0\uB798\uC758 \uC7AC\uCC44\uAE30\uC600\uB358 \uAC83\uC73C\uB85C \uBC1D\uD600\uC84C\uB2E4."
