  m_text: "\uB9C8\uBC95 \uAD50\uD1B5\uBD80\uAC00 \uBE57\uC790\uB8E8\uC758 \uACFC\uC18D
    \uC0AC\uACE0\uB97C \uC904\uC774\uACA0\uB2E4\uBA70 \uD558\uB298 \uACF3\uACF3\uC5D0
