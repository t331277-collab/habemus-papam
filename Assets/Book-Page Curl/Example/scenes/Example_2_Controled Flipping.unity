  m_text: "\uADF8\uB294 \uAD50\uB2E8\uC758 \uC804\uD1B5\uACFC \uADDC\uC728\uC744
    \uBB34\uC5C7\uBCF4\uB2E4 \uC911\uC2DC\uD558\uBA70, \uD63C\uB780\uC2A4\uB7EC\uC6B4
    \uC2DC\uB300\uC77C\uC218\uB85D \uC624\uB798\uB41C \uACC4\uC728\uB85C \uB3CC\uC544\uAC00\uC57C
    \uD55C\uB2E4\uACE0 \uC8FC\uC7A5\uD55C\uB2E4. \uC9C0\uC9C0\uC790\uB4E4\uC740 \uADF8\uC758
