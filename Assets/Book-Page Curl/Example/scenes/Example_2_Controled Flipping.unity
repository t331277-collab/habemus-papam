  m_text: "\uC131\uBB38 \uC55E \uC624\uB798\uB41C \uBE75\uC9D1\uC758 \uC624\uBE10\uC774
    \uC624\uB298 \uC544\uCE68 \uC8FC\uC778\uC5D0\uAC8C \uD734\uAC00 \uC2E0\uCCAD\uC11C\uB97C
    \uC81C\uCD9C\uD588\uB2E4. \uC624\uBE10\uC740 \uC2E0\uCCAD\uC11C\uC5D0\uC11C \u201C\uB9E4\uC77C
