  m_text: "\uC11C\uBD80 \uB3C4\uC2DC\uC758 \uC2DC\uC7A5\uC774 \uC18C\uC74C \uBB38\uC81C\uB97C
    \uD574\uACB0\uD558\uACA0\uB2E4\uBA70 \uBAA8\uB4E0 \uC885\uACFC \uC545\uAE30\uC758
    \uC5F0\uC8FC\uB97C \uAE08\uC9C0\uD588\uB2E4. \uC2DC\uBBFC\uB4E4\uC740 \uC870\uC6A9\uD574\uC9C8
    \uAC83\uC73C\uB85C \uAE30\uB300\uD588\uC9C0\uB9CC, \uC2DC\uAC04\uC744 \uC54C\uB9B4
    \uBC29\uBC95\uC774 \uC0AC\uB77C\uC838 \uC9C1\uC6D0\uACFC \uC0C1\uC778\uB4E4\uC774
    \uC81C\uBA4B\uB300\uB85C \uCD9C\uADFC\uD558\uAE30 \uC2DC\uC791\uD588\uB2E4. \uC2DC\uC7A5\uC740
    \uC0AC\uB78C\uC744 \uACE0\uC6A9\uD574 \uB9E4\uC2DC\uAC04 \uAD11\uC7A5\uC5D0\uC11C
    \uC9C0\uAE08 \uC2DC\uAC01\uC744 \uC678\uCE58\uAC8C \uD588\uC73C\uB098 \uBAA9\uC18C\uB9AC\uAC00
    \uC885\uBCF4\uB2E4 \uC2DC\uB044\uB7FD\uB2E4\uB294 \uBBFC\uC6D0\uC774 \uC3DF\uC544\uC84C\uB2E4.
    \uACB0\uAD6D \uC2DC\uAC01 \uC54C\uB9BC \uB2F4\uB2F9\uC790\uB294 \uB0B4\uC6A9\uC744
    \uB178\uB798\uB85C \uC804\uB2EC\uD588\uACE0, \uC545\uAE30 \uC5C6\uC774 \uB178\uB798\uD558\uB294
    \uAC83\uC774 \uAE08\uC9C0 \uB300\uC0C1\uC778\uC9C0\uB97C \uB450\uACE0 \uB17C\uC7C1\uC774
    \uBC8C\uC5B4\uC84C\uB2E4. \uC2DC\uC7A5\uC740 \uD574\uACB0\uCC45\uC744 \uCC3E\uC744
    \uB54C\uAE4C\uC9C0 \uBBFC\uC6D0 \uC811\uC218 \uC2DC\uAC04\uC744 \uC54C\uB9AC\uB294
    \uC885\uC744 \uCE58\uB77C\uACE0"
