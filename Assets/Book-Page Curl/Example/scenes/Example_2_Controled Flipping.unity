    m_PersistentCalls:
      m_Calls: []
  m_text: "\uC655\uB9BD \uB300\uD559 \uC5F0\uAD6C\uC9C4\uC774 \uAC10\uC790\uC5D0\uAC8C
    \uCE6D\uCC2C\uC744 \uB4E4\uB824\uC8FC\uBA74 \uC218\uD655\uB7C9\uC774 \uB298\uC5B4\uB09C\uB2E4\uB294
    \uC5F0\uAD6C \uACB0\uACFC\uB97C \uBC1C\uD45C\uD588\uB2E4. \uC5F0\uAD6C\uC9C4\uC740
    \uB9E4\uC77C \uBC2D\uC5D0\uC11C \uAC10\uC790\uB4E4\uC5D0\uAC8C \uC544\uB984\uB2F5\uACE0
    \uAC00\uB2A5\uC131\uC774 \uB9CE\uB2E4\uB294 \uB9D0\uC744 \uAC74\uB128 \uACB0\uACFC,
    \uC544\uBB34 \uB9D0\uB3C4 \uD558\uC9C0 \uC54A\uC740 \uBC2D\uBCF4\uB2E4 \uAC10\uC790\uAC00
    \uB450 \uAC1C \uB354 \uC790\uB790\uB2E4\uACE0 \uC124\uBA85\uD588\uB2E4. \uB18D\uBBFC\uB4E4\uC740
    \uC989\uC2DC \uBC2D\uC5D0 \uC74C\uC545\uAC00\uC640 \uC2DC\uC778\uC744 \uACE0\uC6A9\uD588\uC9C0\uB9CC
    \uC778\uAC74\uBE44\uAC00 \uAC10\uC790 \uD310\uB9E4\uC561\uBCF4\uB2E4 \uC5F4 \uBC30\uB098
    \uB9CE\uC774 \uB4E4\uC5C8\uB2E4. \uC774\uD6C4 \uD55C \uB18D\uBBFC\uC774 \uAC10\uC790\uC5D0\uAC8C
    \uC695\uC124\uC744 \uD37C\uBD80\uC740 \uBC2D\uC5D0\uC11C \uAC00\uC7A5 \uD070
    \uAC10\uC790\uAC00 \uB098\uC624\uBA74\uC11C \uC5F0\uAD6C \uACB0\uACFC\uC5D0 \uC758\uBB38\uC774
    \uC81C\uAE30\uB410\uB2E4. \uB300\uD559\uC740 \uADF8 \uAC10\uC790\uAC00 \uBD84\uB178\uB97C
    \uC131\uC7A5 \uB3D9\uB825\uC73C\uB85C \uC0BC\uC740 \uC608\uC678\uC801\uC778 \uC0AC\uB840\uB77C\uACE0
    \uD574\uBA85\uD588\uB2E4."
