  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uBD81\uBD80 \uC0B0\uB9E5\uC758 \uAC70\uB300\uD55C \uC6A9\uC774 \uB9C8\uC744\uC744
    \uC2B5\uACA9\uD558\uB294 \uB300\uC2E0 \uB9E4\uB2EC \uAE08\uD654\uC640 \uAC00\uCD95\uC744
    \uBCF4\uB0B4 \uB2EC\uB77C\uB294 \uC815\uC2DD \uACC4\uC57D\uC11C\uB97C \uC81C\uCD9C\uD588\uB2E4.
    \uC6A9\uC740 \uC9C1\uC811 \uB0A0\uC544\uAC00 \uB9C8\uC744\uC744 \uBD88\uD0DC\uC6B0\uB294
    \uBE44\uC6A9\uC774 \uB108\uBB34 \uCEE4 \uC815\uAE30 \uAD6C\uB3C5 \uBC29\uC2DD\uC73C\uB85C
    \uBC14\uAFE8\uB2E4\uACE0 \uC124\uBA85\uD588\uB2E4. \uACC4\uC57D\uC5D0\uB294 \uAE08\uD654\uB97C
    \uC81C\uB54C \uBCF4\uB0B4\uBA74 \uC5F0\uAE30\uB97C \uBB34\uB8CC\uB85C \uBCF4\uC5EC\uC8FC\uACE0,
    \uAC00\uCD95\uC744 \uCD94\uAC00\uD558\uBA74 \uAE30\uB150\uC0AC\uC9C4\uB3C4 \uCC0D\uC5B4
    \uC900\uB2E4\uB294 \uB0B4\uC6A9\uC774 \uD3EC\uD568\uB410\uB2E4. \uC8FC\uBBFC\uB4E4\uC774
    \uACC4\uC57D\uC744 \uAC70\uC808\uD558\uC790 \uC6A9\uC740 \uCCAB \uB2EC \uBB34\uB8CC
    \uCCB4\uD5D8\uC744 \uC81C\uC548\uD558\uBA70 \uC0B0 \uC704\uC5D0\uC11C \uC791\uC740
    \uBD88\uAF43\uC744 \uC120\uBCF4\uC600\uB2E4. \uC655\uC2E4\uC740 \uC774\uAC83\uC774
    \uC57D\uD0C8\uC778\uC9C0 \uC0C1\uAC70\uB798\uC778\uC9C0 \uD310\uB2E8\uD558\uC9C0
    \uBABB\uD574 \uC138\uAE08\uBD80\uD130 \uBD80\uACFC\uD55C \uB4A4 \uBC95\uC801
    \uAC80\uD1A0\uB97C \uC2DC\uC791\uD588\uB2E4."
  m_isRightToLeft: 0
