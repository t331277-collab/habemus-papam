  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uD604\uC7A5\uC5D0 \uC788\uB358 \uAD81\uC815 \uC694\uB9AC\uC0AC\uB294
    \u201C\uD5A5\uC740 \uD6CC\uB96D\uD558\uC9C0\uB9CC \uC544\uC9C1 \uAC04\uC774 \uBD80\uC871\uD558\uB2E4\u201D\uBA70
    \uC18C\uAE08 \uB450 \uD3EC\uB300\uB97C \uCD94\uAC00\uD588\uB2E4.\n\n\uC655\uC2E4\uC740
    \uD574\uB2F9 \uC218\uD504\uB97C \uBB38\uD654\uC7AC\uB85C \uC9C0\uC815\uD560\uC9C0,
    \uC810\uC2EC \uBA54\uB274\uB85C \uC81C\uACF5\uD560\uC9C0 \uB17C\uC758 \uC911\uC774\uB2E4.\n\uC655\uC2E4\uC740
    \uD604\uC7AC \uC774 \uC218\uD504\uB97C \uBB38\uD654\uC7AC\uB85C \uC9C0\uC815\uD560\uC9C0,
    \uC655\uC758 \uC0DD\uC77C \uC5F0\uD68C\uC5D0 \uC81C\uACF5\uD560\uC9C0 \uB17C\uC758
    \uC911\uC774\uB2E4. \uC77C\uBD80 \uADC0\uC871\uB4E4\uC740 \u201C300\uB144\uC744
    \uAE30\uB2E4\uB9B0 \uC74C\uC2DD\uC774\uB77C\uBA74 \uC6B0\uB9AC\uB3C4 \uC870\uAE08
    \uAE30\uB2E4\uB9B4 \uC218 \uC788\uB2E4\u201D\uBA70 \uAE0D\uC815\uC801\uC778 \uBC18\uC751\uC744
    \uBCF4\uC600\uC9C0\uB9CC, \uBCF4\uAC74\uCCAD\uC740 \u201C\uC720\uD1B5\uAE30\uD55C
    \uD45C\uAE30\uAC00 \uC5C6\uC5B4 \uD310\uB2E8\uC774 \uC5B4\uB835\uB2E4\u201D\uB294
    \uC785\uC7A5\uC744 \uB0C8\uB2E4."
