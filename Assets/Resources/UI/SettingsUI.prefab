  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "***\uC784\uC2DC \uD14D\uC2A4\uD2B8***\n\uD50C\uB808\uC774 \uBC29\uBC95\r\n\r\n\uBAA9\uD45C\r\n\uCF58\uD074\uB77C\uBCA0\uAC00
    \uB05D\uB0A0 \uB54C\uAE4C\uC9C0 \uAD50\uD669\uC73C\uB85C \uC120\uCD9C\uB418\uB294
    \uC77C\uC744 \uD53C\uD558\uC138\uC694.\r\n\uC9C0\uC9C0\uB97C \uB108\uBB34 \uB9CE\uC774
    \uBC1B\uC9C0 \uC54A\uACE0 \uD3C9\uD654\uB85C\uC6B4 \uB178\uD6C4\uB97C \uB9DE\uC774\uD558\uB294
    \uAC83\uC774 \uBAA9\uD45C\uC785\uB2C8\uB2E4.\r\n\r\n\uAE30\uBCF8 \uC870\uC791\r\n\uC774\uB3D9:
    \uC124\uC815\uD55C \uC774\uB3D9 \uB2E8\uCD95\uD0A4\r\n\uAE30\uB3C4: \uC124\uC815\uD55C
    \uAE30\uB3C4 \uB2E8\uCD95\uD0A4\r\n\uC5F0\uC124: \uC124\uC815\uD55C \uC5F0\uC124
    \uB2E8\uCD95\uD0A4\r\n\uC124\uC815 \uC5F4\uAE30/\uB2EB\uAE30: ESC\r\n\r\n\uC9C4\uD589
    \uBC29\uC2DD\r\n\uC81C\uD55C \uC2DC\uAC04 \uC548\uC5D0 \uD68C\uC758\uC7A5\uC744
    \uC774\uB3D9\uD558\uBA70 \uCD94\uAE30\uACBD\uB4E4\uACFC \uC0C1\uD638\uC791\uC6A9\uD569\uB2C8\uB2E4.\r\n\uAE30\uB3C4\uC640
    \uC5F0\uC124\uC744 \uC801\uC808\uD788 \uC0AC\uC6A9\uD574 \uC9C0\uC9C0\uB3C4\uB97C
    \uB192\uC774\uC138\uC694.\r\n\uC2DC\uAC04\uC774 \uC9C0\uB098\uBA74 \uC0C1\uD669
    \uC774\uBCA4\uD2B8\uAC00 \uBC1C\uC0DD\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\r\n\r\n\uC8FC\uC758\uD560
    \uC810\r\n\uB0A8\uC740 \uC2DC\uAC04\uC774 0\uC774 \uB418\uBA74 \uCF58\uD074\uB77C\uBCA0\uAC00
    \uC885\uB8CC\uB429\uB2C8\uB2E4.\r\n\uC120\uD0DD\uC5D0 \uB530\uB77C \uC9C0\uC9C0\uB3C4\uC640
    \uC9C4\uD589 \uC0C1\uD669\uC774 \uB2EC\uB77C\uC9C8 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\r\n\uC0C8
    \uAC8C\uC784\uC744 \uC2DC\uC791\uD558\uBA74 \uD604\uC7AC \uC800\uC7A5\uB41C \uC9C4\uD589
    \uC0C1\uD669\uC774 \uC0AD\uC81C\uB429\uB2C8\uB2E4."
  m_isRightToLeft: 0
